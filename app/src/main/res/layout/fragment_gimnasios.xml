<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gains_bg_deep"
    android:padding="20dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="55dp"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="@color/gains_item_surface"
        app:cardElevation="4dp"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/gains_text_tertiary" />

            <EditText
                android:id="@+id/etSearchGym"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Buscar gimnasio o ciudad..."
                android:textColorHint="@color/gains_text_tertiary"
                android:textColor="@color/gains_text_primary"
                android:paddingStart="12dp"
                android:textSize="16sp"
                android:inputType="text"
                android:imeOptions="actionSearch"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Encuentra tu centro"
        android:textColor="@color/gains_text_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="280dp"
        app:cardCornerRadius="32dp"
        app:cardBackgroundColor="@color/gains_card_surface"
        app:cardElevation="10dp">
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/map_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFindClosest"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="20dp"
        android:text="BUSCAR CERCANO"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        android:backgroundTint="@color/gains_accent_orange"
        android:textColor="@color/white"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardContactInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/gains_item_surface">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvGymName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Gimnasio"
                android:textColor="@color/gains_accent_orange"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/tvGymAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvGymName"
                android:text="Dirección completa"
                android:textColor="@color/gains_text_secondary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDirections"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvGymAddress"
                android:layout_marginTop="8dp"
                android:text="CÓMO LLEGAR"
                android:textColor="@color/gains_accent_orange"
                app:icon="@android:drawable/ic_menu_directions"
                app:iconTint="@color/gains_accent_orange" />

            <ImageButton
                android:id="@+id/btnCall"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_call"
                app:tint="@color/gains_accent_orange"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>