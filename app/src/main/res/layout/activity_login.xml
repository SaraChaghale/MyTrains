<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/windowBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0.4"
            android:scaleType="centerCrop"
            android:src="@drawable/ejercicio"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_overlay" />

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/arrow"
            app:tint="?attr/colorOnSurface"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="220dp"
                android:layout_height="90dp"

                android:layout_marginBottom="40dp"
                android:adjustViewBounds="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TU CAMBIO"
                android:textColor="?attr/colorOnSurface"
                android:textSize="34sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMPIEZA AQUÍ"
                android:textColor="?attr/colorPrimary"
                android:textSize="34sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="-10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accede a tu zona de entrenamiento"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="16sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="28dp"
                android:letterSpacing="0.01" />

            <EditText
                android:id="@+id/etUser"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_input_glass"
                android:hint="Correo electrónico"
                android:paddingHorizontal="20dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOutline"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:inputType="text" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_input_glass"
                android:hint="Contraseña"
                android:paddingHorizontal="20dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOutline"
                android:textSize="15sp"
                android:inputType="textPassword" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForgotPassword"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="¿Olvidaste tu contraseña?"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                app:rippleColor="?attr/colorSecondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:text="ENTRAR"
                android:textColor="?attr/colorOnPrimary"
                android:textStyle="bold"
                android:textSize="18sp"
                app:cornerRadius="16dp"
                app:backgroundTint="?attr/colorPrimary" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>