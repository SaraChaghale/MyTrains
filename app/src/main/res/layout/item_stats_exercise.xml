<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardExercise"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/gains_item_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp"
    app:strokeColor="#4CAF50"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/tvStatExerciseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivDoneBadge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/tvStatExerciseName"
            android:src="@drawable/check"
            android:visibility="gone"
            app:tint="#4CAF50" />

        <ImageView
            android:id="@+id/ivExpandIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:src="@android:drawable/arrow_down_float"
            app:tint="?attr/colorOnSurface" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layoutExpandable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivExerciseImage"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:layout_marginBottom="8dp"
            android:src="@drawable/exercise" /> <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#592707"
        android:padding="4dp"
        android:text="COMENTARIO ENTRENADOR"
        android:textColor="#FFCDD2"
        android:textSize="10sp"
        android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatCoachComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#180C00"
            android:padding="8dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="#592707" android:gravity="center" android:padding="2dp" android:text="SERIES" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:background="#592707" android:gravity="center" android:padding="2dp" android:text="RANGO REPS" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="#592707" android:gravity="center" android:padding="2dp" android:text="RIR" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="#592707" android:gravity="center" android:padding="2dp" android:text="REST" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/tvTargetSeries" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="#180C00" android:gravity="center" android:padding="8dp" android:textColor="?attr/colorOnSurface" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvTargetReps" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:background="#180C00" android:gravity="center" android:padding="8dp" android:textColor="?attr/colorOnSurface" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvTargetRIR" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="#180C00" android:gravity="center" android:padding="8dp" android:textColor="?attr/colorOnSurface" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvTargetRest" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="#180C00" android:gravity="center" android:padding="8dp" android:textColor="?attr/colorOnSurface" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:background="#9B5B38" android:gravity="center" android:padding="2dp" android:text="PESO" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:background="#9B5B38" android:gravity="center" android:padding="2dp" android:text="REP.REALIZADA" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:background="#9B5B38" android:gravity="center" android:padding="2dp" android:text="REP.POSIBLE" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <EditText android:id="@+id/etWeight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:background="#261300" android:gravity="center" android:inputType="numberDecimal" android:padding="8dp" android:textColor="?attr/colorOnSurface" android:textSize="15sp" android:textStyle="bold" />
            <EditText android:id="@+id/etRepReal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:background="#261300" android:gravity="center" android:inputType="number" android:padding="8dp" android:textColor="?attr/colorOnSurface" android:textSize="15sp" android:textStyle="bold" />
            <EditText android:id="@+id/etRepPos" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:background="#261300" android:gravity="center" android:inputType="number" android:padding="8dp" android:textColor="?attr/colorOnSurface" android:textSize="15sp" android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="MIS NOTAS PARA EL ENTRENADOR"
            android:textColor="?attr/colorPrimary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etUserNotes"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#261300"
            android:gravity="top"
            android:layout_marginTop="5dp"
            android:padding="8dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="#444444"
            android:hint="Opcional..."
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnCompleteTask"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="?attr/colorPrimary"
            android:text="GUARDAR"
            android:textColor="?attr/colorOnPrimary"
            android:textStyle="bold"
            app:cornerRadius="8dp" />
    </LinearLayout>
</LinearLayout>
</com.google.android.material.card.MaterialCardView>